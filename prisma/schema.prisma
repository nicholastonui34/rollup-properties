// Rollup Properties — data model (BRIEF.md §7)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SEEKER
  LISTER
  VERIFIER
  ADMIN
}

enum ListingPurpose {
  RENT
  SALE
}

enum PropertyType {
  BEDSITTER
  STUDIO
  APARTMENT
  MAISONETTE
  BUNGALOW
  TOWNHOUSE
  COMMERCIAL
  LAND
  HOSTEL
  SHARED_APARTMENT
}

enum ListingStatus {
  DRAFT
  SUBMITTED
  IN_VERIFICATION
  NEEDS_INFO
  REJECTED
  LIVE
  TAKEN
  EXPIRED
  SUSPENDED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_INFO
}

enum PaymentProvider {
  PAYSTACK
  MPESA
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentPurpose {
  UNLOCK
  BUNDLE
  FEATURED
  SUBSCRIPTION
  LISTING_FEE
}

enum ReportStatus {
  OPEN
  INVESTIGATING
  REFUNDED
  REJECTED
}

enum TourTimeSlot {
  MORNING
  AFTERNOON
  EVENING
}

enum TourType {
  IN_PERSON
  VIDEO_CALL
}

enum TourRequestStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum MediaRequestStatus {
  NEW
  SCHEDULED
  DELIVERED
}

// Schema-only for now (spec §8): no billing/enforcement wired up, just the
// data model so a real subscription rail can be added later without another
// migration. FREE is the only tier actually in effect.
enum PlanTier {
  FREE
  PRO
}

model User {
  id            String    @id @default(cuid())
  name          String
  phone         String    @unique
  email         String?   @unique
  passwordHash  String
  role          Role      @default(SEEKER)
  idNumber      String?
  idVerifiedAt  DateTime?
  bannedAt      DateTime?
  banReason     String?
  planTier      PlanTier  @default(FREE)
  // Cumulative free listing publishes (V2 §14) — admin-adjustable for comps/overrides.
  // Actual usage is COUNTED from Listing.publishedAt, not stored as a running tally,
  // so it can never drift out of sync.
  freeListingQuota Int    @default(20)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listings      Listing[]      @relation("ListerListings")
  verifications Verification[]
  unlocks       Unlock[]
  payments      Payment[]
  savedListings SavedListing[]
  savedSearches SavedSearch[]
  reports       Report[]
  mediaRequests MediaRequest[]
}

model Area {
  id       String    @id @default(cuid())
  county   String
  town     String
  name     String
  slug     String    @unique
  listings Listing[]

  @@unique([county, town, name])
  @@index([town])
}

model Listing {
  id               String         @id @default(cuid())
  listerId         String
  lister           User           @relation("ListerListings", fields: [listerId], references: [id])
  title            String
  slug             String         @unique
  description      String
  purpose          ListingPurpose
  propertyType     PropertyType
  priceKes         Int
  depositKes       Int?
  serviceChargeKes Int?
  sizeSqm          Int?
  tourEmbedUrl     String?
  videoUrl         String?
  managerWebsiteUrl   String?
  managerAgencyName   String?
  county           String
  town             String
  areaId           String?
  area             Area?          @relation(fields: [areaId], references: [id])
  estate           String?
  streetAddress    String
  lat              Float?
  lng              Float?
  geocodedAt       DateTime?
  amenitiesSnapshot Json?
  amenitiesFetchedAt DateTime?
  bedrooms         Int            @default(0)
  bathrooms        Int            @default(0)
  furnished        Boolean        @default(false)
  amenities        String[]
  status           ListingStatus  @default(DRAFT)
  // First-ever successful publish (submit-for-verification) — set once and never
  // cleared. Marks that this listing already consumed a free-quota slot or paid the
  // KES 99 fee, so resubmitting after edits/NEEDS_INFO never charges twice.
  publishedAt      DateTime?
  verifiedAt       DateTime?
  verifiedById     String?
  lastConfirmedAt  DateTime?
  expiresAt        DateTime?
  featuredUntil    DateTime?
  viewCount        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  images        ListingImage[]
  verifications Verification[]
  unlocks       Unlock[]
  payments      Payment[]
  savedBy       SavedListing[]
  reports       Report[]
  tourRequests  TourRequest[]
  mediaRequests MediaRequest[]

  @@index([status, purpose, town])
  @@index([areaId])
  @@index([priceKes])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  position  Int     @default(0)
  isCover   Boolean @default(false)
}

model TourRequest {
  id            String            @id @default(cuid())
  listingId     String
  listing       Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  email         String?
  preferredDate DateTime
  timeSlot      TourTimeSlot
  tourType      TourType
  message       String?
  status        TourRequestStatus @default(PENDING)
  createdAt     DateTime          @default(now())

  @@index([listingId, status])
}

model CareerApplication {
  id        String   @id @default(cuid())
  // Static role slug from src/lib/careers.ts, not a DB relation — roles are
  // edited in code (V2 §6 lets either DB or a data file own the role list;
  // a data file needs no admin CRUD for an MVP-sized roles page). Null means
  // a general/talent-pool application submitted with no specific role open.
  roleSlug  String?
  name      String
  phone     String
  email     String?
  cvUrl     String?
  note      String?
  createdAt DateTime @default(now())

  @@index([roleSlug])
}

model MediaRequest {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  listingId     String?
  listing       Listing?           @relation(fields: [listingId], references: [id])
  services      String[]
  location      String
  preferredDate DateTime?
  notes         String?
  status        MediaRequestStatus @default(NEW)
  createdAt     DateTime           @default(now())

  @@index([status])
}

model Verification {
  id           String             @id @default(cuid())
  listingId    String
  listing      Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  verifierId   String
  verifier     User               @relation(fields: [verifierId], references: [id])
  status       VerificationStatus @default(PENDING)
  notes        String?
  evidenceUrls String[]
  createdAt    DateTime           @default(now())
}

model Unlock {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])
  createdAt DateTime @default(now())

  report Report?

  @@unique([userId, listingId])
}

model Payment {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  listingId    String?
  listing      Listing?        @relation(fields: [listingId], references: [id])
  amountKes    Int
  provider     PaymentProvider @default(PAYSTACK)
  providerRef  String          @unique
  phone        String?
  status       PaymentStatus   @default(PENDING)
  purpose      PaymentPurpose  @default(UNLOCK)
  refundedAt   DateTime?
  refundReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  unlock Unlock?

  @@index([listingId])
  @@index([status])
}

model SavedListing {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, listingId])
}

model SavedSearch {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  filtersJson   Json
  alertsEnabled Boolean   @default(false)
  lastAlertedAt DateTime?
  createdAt     DateTime  @default(now())
}

model Report {
  id             String       @id @default(cuid())
  listingId      String
  listing        Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporterId     String
  reporter       User         @relation(fields: [reporterId], references: [id])
  unlockId       String?      @unique
  unlock         Unlock?      @relation(fields: [unlockId], references: [id])
  reason         String
  details        String?
  status         ReportStatus @default(OPEN)
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
}
